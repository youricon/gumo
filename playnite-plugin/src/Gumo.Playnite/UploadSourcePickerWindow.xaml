<Window x:Class="Gumo.Playnite.UploadSourcePickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gumo Upload Source"
        Width="360"
        Height="170"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0"
               TextWrapping="Wrap"
               VerticalAlignment="Center"
               Text="Choose what you want to upload to Gumo." />

    <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                HorizontalAlignment="Right">
      <Button Content="File or Archive"
              Width="110"
              Margin="0,0,8,0"
              Click="OnFileClick" />
      <Button Content="Folder"
              Width="80"
              Margin="0,0,8,0"
              Click="OnFolderClick" />
      <Button Content="Cancel"
              Width="80"
              IsCancel="True" />
    </StackPanel>
  </Grid>
</Window>
